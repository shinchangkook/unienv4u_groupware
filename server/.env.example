# 서버 포트
PORT=4000

# JWT 서명 비밀키 — 운영 시 반드시 강력한 무작위 문자열로 교체하세요.
# 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production-please-use-a-long-random-secret

# 액세스 토큰 유효기간
JWT_EXPIRES=12h

# 주민번호 등 민감정보 AES-256-GCM 암호화 키 (64 hex = 32 bytes).
# 미설정 시 JWT_SECRET 에서 파생(개발용). 운영은 반드시 별도 키 지정:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JUMIN_KEY=

# SQLite 데이터 파일 경로 (server/ 기준 상대경로)
DB_FILE=./data/groupware.db

# 정적 프론트엔드(index.html)를 서버에서 함께 제공할지 여부
SERVE_FRONTEND=true

# CORS 허용 오리진 (쉼표 구분). 비워두면 모두 허용(개발용).
CORS_ORIGIN=
